# DS TORKS VENTURES — Environment Variables
# Copy this file to .env and fill in your real values.

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000

# ── Admin Access Token ────────────────────────────────────────────────────────
# Required header for all /api/admin/* endpoints.
# Header format: x-admin-token: <your-token>
ADMIN_SECRET_TOKEN=change_me_to_a_long_random_string

# ── Payment Gateway ───────────────────────────────────────────────────────────
# Options: mock | mtn | vodafone
#   mock        — Testing mode (no real payments). OTP is always "123456".
#   mtn         — Use MTN Mobile Money (requires MTN Developer Portal credentials)
#   vodafone    — Use Vodafone Cash (requires Vodafone API credentials)
PAYMENT_GATEWAY_PROVIDER=mock

# ── MTN Mobile Money (only needed if PAYMENT_GATEWAY_PROVIDER=mtn) ────────────
# Get these from: https://momodeveloper.mtn.com/
MTN_API_USER=your_mtn_api_user_id
MTN_API_KEY=your_mtn_api_key
MTN_SUBSCRIPTION_KEY=your_mtn_subscription_key
MTN_PRIMARY_KEY=your_primary_key
MTN_TARGET_ENVIRONMENT=sandbox   # or "live" for production
MTN_CALLBACK_HOST=localhost      # Your publicly accessible domain for webhooks

# ── Currency ──────────────────────────────────────────────────────────────────
PAYMENT_CURRENCY=GHS

# ── AdSense (optional) ────────────────────────────────────────────────────────
# Replace the placeholder ID in your HTML files with your real AdSense publisher ID
# DS_AD_CLIENT=ca-pub-XXXXXXXXXXXXXXXX

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite database file path (default: ./data/dstorks.db)
# DB_PATH=./data/dstorks.db