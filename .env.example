# Server Configuration
PORT=3000

# Admin Security
# Change this to a secure random string for production
ADMIN_SECRET_TOKEN=change_me_now

# Payment Gateway Provider
# Options: mock, paystack, mtn, vodafone
PAYMENT_GATEWAY_PROVIDER=mock

# Paystack API Credentials
# Get these from your Paystack Dashboard
PAYSTACK_SECRET_KEY=your_paystack_secret_key
PAYSTACK_CALLBACK_URL=http://localhost:3000/shop

# MTN Mobile Money API Credentials
# Get these from https://momodeveloper.mtn.com/
MTN_API_USER=your_api_user_uuid
MTN_API_KEY=your_api_key
MTN_SUBSCRIPTION_KEY=your_subscription_key
MTN_PRIMARY_KEY=your_primary_key
MTN_TARGET_ENVIRONMENT=sandbox
# Options: sandbox (for testing), live (for real payments)